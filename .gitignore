# AI-002: .gitignore
# 参考: docs/plan/README.md § 三、目录结构设计

# 向量库（通过 Actions Cache 持久化，不提交到 git）
data/vector_store/
data/reply_index/

# 运行时数据（不提交到 git）
archive/articles/
archive/rejected/
data/seen_ids.json
data/comment_thread_map.json
data/dedup_cache.json

# 环境变量
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# HuggingFace model cache
.cache/
